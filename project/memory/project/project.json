{
  "schemaVersion": "cofabric.memory.project.v1",
  "name": "Mindful Journal",
  "oneLineDescription": "A journaling + mood tracking web app with AI-generated reflections",
  "whatItIs": "A journaling + mood tracking web app with AI-generated reflections.",
  "stack": [
    {
      "name": "next",
      "version": "14.2.5",
      "purpose": "React framework"
    },
    {
      "name": "react",
      "version": "^18",
      "purpose": "UI library"
    },
    {
      "name": "react-dom",
      "version": "^18",
      "purpose": "React DOM rendering"
    },
    {
      "name": "@supabase/supabase-js",
      "version": "^2.39.0",
      "purpose": "Supabase client"
    },
    {
      "name": "openai",
      "version": "^4.38.5",
      "purpose": "OpenAI API client"
    },
    {
      "name": "stripe",
      "version": "^14.21.0",
      "purpose": "Stripe payments"
    },
    {
      "name": "tailwindcss",
      "version": "^3.4.1",
      "purpose": "CSS framework"
    }
  ],
  "externalIntegrations": [
    {
      "service": "Supabase",
      "envVars": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "OpenAI",
      "envVars": [
        "OPENAI_API_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "Stripe",
      "envVars": [
        "STRIPE_SECRET_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "NextAuth",
      "envVars": [
        "NEXTAUTH_URL",
        "NEXTAUTH_SECRET"
      ],
      "clientLocation": null
    }
  ],
  "coreUserFlows": [
    "Users can create, edit, and delete journal entries",
    "Users can log their daily mood with a limit of 3 logs per day",
    "Users can view a timeline of their entries and moods",
    "Paid users can generate AI insights from their journal content",
    "Users can search through their entries and tags"
  ],
  "outOfScope": []
}