{
  "schemaVersion": "cofabric.memory.project.v1",
  "name": "Mindful Journal",
  "oneLineDescription": "A journaling + mood tracking web app with AI-generated reflections",
  "whatItIs": "A journaling + mood tracking web app with AI-generated reflections.",
  "stack": [
    {
      "name": "next",
      "version": "14.2.13",
      "purpose": "React framework"
    },
    {
      "name": "react",
      "version": "^18",
      "purpose": "UI library"
    },
    {
      "name": "@supabase/supabase-js",
      "version": "^2.45.4",
      "purpose": "Database and auth client"
    },
    {
      "name": "openai",
      "version": "^4.63.0",
      "purpose": "AI insights generation"
    },
    {
      "name": "stripe",
      "version": "^16.12.0",
      "purpose": "Payment processing"
    },
    {
      "name": "tailwindcss",
      "version": "^3.4.1",
      "purpose": "CSS framework"
    }
  ],
  "externalIntegrations": [
    {
      "service": "Supabase",
      "envVars": [
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "SUPABASE_SERVICE_ROLE_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "OpenAI",
      "envVars": [
        "OPENAI_API_KEY"
      ],
      "clientLocation": null
    },
    {
      "service": "Stripe",
      "envVars": [
        "STRIPE_SECRET_KEY",
        "NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY",
        "STRIPE_WEBHOOK_SECRET"
      ],
      "clientLocation": null
    }
  ],
  "coreUserFlows": [
    "Users can create, edit, and delete journal entries",
    "Users can log their mood daily",
    "Users can view timeline of entries and moods",
    "Paid users can generate AI insights from their journal data",
    "Users can search through entries and tags"
  ],
  "outOfScope": []
}